<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodStreetMAUI.ViewModels"
             xmlns:models="clr-namespace:FoodStreetMAUI.Models"
             x:Class="FoodStreetMAUI.Views.MainPage"
             BackgroundColor="#0F0F16">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowSpacing="0">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#13131C" StrokeThickness="0" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="{Binding UiTexts.HeaderTitle}" FontSize="15" FontAttributes="Bold" TextColor="#F0A030"/>
                    <Label Text="{Binding UiTexts.HeaderSubtitle}" FontSize="10" TextColor="#666666"/>
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <Label Text="{Binding GpsStatusText}" FontSize="10" TextColor="#888888" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Language selector -->
        <Border Grid.Row="1" BackgroundColor="#13131C" Padding="10,6">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalOptions="Center">
                <Label Text="{Binding UiTexts.LanguageLabel}" FontSize="11" TextColor="#888888" VerticalOptions="Center"/>
                <Grid Grid.Column="1" HorizontalOptions="End">
                    <ImageButton Source="icon_translate.svg"
                         WidthRequest="40"
                         HeightRequest="40"
                         BackgroundColor="#F0A030"
                         CornerRadius="20"
                         Command="{Binding ShowLanguageModalCommand}"
                         Padding="8"
                         Aspect="AspectFit"/>
                </Grid>
            </Grid>
        </Border>

        <!-- GPS coords bar -->
        <Border Grid.Row="2" BackgroundColor="#13131C" StrokeThickness="0" Padding="12,5">
            <Grid ColumnDefinitions="*,Auto">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="{Binding UiTexts.GpsIcon}" FontSize="12"/>
                    <Label Text="{Binding CoordinateText}" FontSize="11" TextColor="#3ADB76" VerticalOptions="Center"/>
                    <Label Text="{Binding AccuracyText}" FontSize="10" TextColor="#555555" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Grid.Column="1" Text="{Binding SessionTimeText}" FontSize="11" TextColor="#888888" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Main map area -->
        <Grid Grid.Row="3" BackgroundColor="#0F0F16">
            <!-- Mapsui + OpenStreetMap (Mapsui.Tiling) — không cần Google Maps API key -->
            <Grid x:Name="MapHost" BackgroundColor="#111820"/>

            <!-- Legend (bottom-left) -->
            <Border BackgroundColor="#1A1A26" Padding="8" StrokeShape="RoundRectangle 8" HorizontalOptions="Start" VerticalOptions="End" Margin="12,0,0,12" Opacity="0.95">
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="Blue" CornerRadius="3"/>
                        <Label Text="{Binding UiTexts.LegendYou}" FontSize="12" TextColor="#D0D0D0"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="Green" CornerRadius="3"/>
                        <Label Text="{Binding UiTexts.LegendDestination}" FontSize="12" TextColor="#D0D0D0"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="Yellow" CornerRadius="3"/>
                        <Label Text="{Binding UiTexts.LegendApproaching}" FontSize="12" TextColor="#D0D0D0"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="Red" CornerRadius="3"/>
                        <Label Text="{Binding UiTexts.LegendNearest}" FontSize="12" TextColor="#D0D0D0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Floating top elements -->
            <VerticalStackLayout Spacing="0" VerticalOptions="Start" InputTransparent="True" CascadeInputTransparent="False">
                <Label Text="{Binding NearestPoiSummary}" FontSize="11" TextColor="Red" FontAttributes="Bold"
                       Margin="14,6,14,0" LineBreakMode="TailTruncation"
                       IsVisible="{Binding ShowNearestPoiBanner}"
                       InputTransparent="False"/>

                <!-- Now playing -->
                <Border Margin="10,8" BackgroundColor="#1F1A10"
                        Stroke="#F0A030" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 12" Padding="12,10"
                        IsVisible="{Binding IsPlayingAudio}"
                        InputTransparent="False">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowFullDescriptionCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding UiTexts.NowPlayingHeader}" FontSize="10" TextColor="#F0A030"/>
                            <Label Text="{Binding NowPlayingTitle}" FontSize="13" FontAttributes="Bold"
                                   TextColor="#E8E0D0" LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding NowPlayingDesc}" FontSize="11" TextColor="#999999"
                                   LineBreakMode="TailTruncation" MaxLines="2"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="{Binding UiTexts.StopAudioButton}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"
                                BackgroundColor="#E03030" TextColor="#FFFFFF"
                                HeightRequest="40" CornerRadius="8" Padding="12,0"
                                Command="{Binding StopAudioCommand}"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Center map button -->
            <Button x:Name="CenterMapButton"
                    Text="{Binding UiTexts.GpsIcon}"
                    FontSize="16"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"

                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,12,60"

                    BackgroundColor="#FFFFFF"
                    TextColor="#1A73E8"

                    Clicked="OnCenterMapClicked">

                <Button.Shadow>
                    <Shadow Brush="Black" Offset="1,1" Radius="4" Opacity="0.3"/>
                </Button.Shadow>
            </Button>

            <!-- Button to POI list -->
            <Button Text="{Binding UiTexts.PoiListButton}"
                    HorizontalOptions="End" VerticalOptions="End"
                    Margin="16" HeightRequest="40" CornerRadius="20"
                    BackgroundColor="#1A1A26" TextColor="White"
                    BorderColor="#2A2A3A" BorderWidth="1"
                    FontSize="12" Padding="16,0"
                    Clicked="OnOpenPoiListClicked" />
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="4" BackgroundColor="#13131C" StrokeThickness="0" Padding="12,6">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="{Binding VisitedSummaryText}"
                           FontSize="14" FontAttributes="Bold" TextColor="#E0E0F0" HorizontalOptions="Center"/>
                    <Label Text="{Binding UiTexts.StatsVisitedLabel}" FontSize="9" TextColor="#555555" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="{Binding DistanceText}"
                           FontSize="14" FontAttributes="Bold" TextColor="#E0E0F0" HorizontalOptions="Center"/>
                    <Label Text="{Binding UiTexts.StatsDistanceLabel}" FontSize="9" TextColor="#555555" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label Text="{Binding SessionTimeText}"
                           FontSize="14" FontAttributes="Bold" TextColor="#E0E0F0" HorizontalOptions="Center"/>
                    <Label Text="{Binding UiTexts.StatsTimeLabel}" FontSize="9" TextColor="#555555" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Bottom action bar -->
        <Border Grid.Row="5" BackgroundColor="#13131C" StrokeThickness="0" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="{Binding StartButtonText}"
                        BackgroundColor="{Binding StartButtonColor}"
                        TextColor="White" FontSize="13"
                        CornerRadius="10" HeightRequest="44"
                        Command="{Binding ToggleGpsCommand}"/>

                <ImageButton Grid.Column="1"
                             Source="icon_qr.svg"
                             WidthRequest="44"
                             HeightRequest="44"
                             BackgroundColor="#F0A030"
                             CornerRadius="22"
                             Padding="10"
                             Aspect="AspectFit"
                             Clicked="OnScanQrClicked" />
            </Grid>
        </Border>

        <!-- Selected POI Modal Bottom Sheet -->
        <Grid Grid.Row="0" Grid.RowSpan="6"
              BackgroundColor="#B3000000"
              IsVisible="{Binding IsPoiModalVisible}">
            <!-- Click background to close -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePoiModalCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="#1E2A24"
                    VerticalOptions="End"
                    Margin="0"
                    Padding="20,15,20,30"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0">
                <!-- Prevent closing when clicking inside the sheet -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <!-- Handle UI indicator -->
                    <BoxView HeightRequest="4" WidthRequest="40" Color="#4A4A5A" CornerRadius="2" HorizontalOptions="Center"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="{Binding UiTexts.PoiModalPlayButton}" FontSize="18" BackgroundColor="#F0A030" TextColor="#0F0F16"
                                BorderColor="#F8C070" BorderWidth="1"
                                CornerRadius="22" HeightRequest="44" WidthRequest="44"
                                HorizontalOptions="Start"
                                Clicked="OnPlaySelectedPoiAudioClicked"/>

                        <Button Grid.Column="1" Text="{Binding UiTexts.PoiModalViewDetailButton}" FontSize="14" BackgroundColor="#2A8F3A" TextColor="White"
                                CornerRadius="12" HeightRequest="44" HorizontalOptions="End"
                                Clicked="OnViewDetailsClicked"/>
                    </Grid>

                    <Label Text="{Binding SelectedPoiTitle}" FontSize="18" FontAttributes="Bold" TextColor="#7BD88F" Margin="0,10,0,0"/>

                    <ScrollView MaximumHeightRequest="400" VerticalScrollBarVisibility="Default">
                        <Label Text="{Binding SelectedPoiDesc}" FontSize="14" TextColor="#D0D0D0" LineHeight="1.4" LineBreakMode="WordWrap"/>
                    </ScrollView>

                    <Button Text="{Binding UiTexts.CommonClose}" 
                            Command="{Binding ClosePoiModalCommand}" 
                            BackgroundColor="#2A2A3A" 
                            TextColor="#CCCCCC"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="20" HeightRequest="44"
                            Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Now Playing Modal Bottom Sheet -->
        <Grid Grid.Row="0" Grid.RowSpan="6"
              BackgroundColor="#B3000000"
              IsVisible="{Binding IsNowPlayingModalVisible}">
            <!-- Click background to close -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseNowPlayingModalCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="#1F1A10"
                    VerticalOptions="End"
                    Margin="0"
                    Padding="20,15,20,30"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0">
                <!-- Prevent closing when clicking inside the sheet -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <!-- Handle UI indicator -->
                    <BoxView HeightRequest="4" WidthRequest="40" Color="#4A4A5A" CornerRadius="2" HorizontalOptions="Center"/>

                    <Label Text="{Binding NowPlayingTitle}" FontSize="18" FontAttributes="Bold" TextColor="#F0A030" Margin="0,10,0,0"/>

                    <ScrollView MaximumHeightRequest="400" VerticalScrollBarVisibility="Default">
                        <Label Text="{Binding NowPlayingDesc}" FontSize="14" TextColor="#D0D0D0" LineHeight="1.4" LineBreakMode="WordWrap"/>
                    </ScrollView>

                    <Button Text="{Binding UiTexts.CommonClose}" 
                            Command="{Binding CloseNowPlayingModalCommand}" 
                            BackgroundColor="#2A2A3A" 
                            TextColor="#CCCCCC"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="20" HeightRequest="44"
                            Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Modal chọn ngôn ngữ -->
        <Grid Grid.Row="0" Grid.RowSpan="6"
              BackgroundColor="#B3000000"
              IsVisible="{Binding IsLanguageModalVisible}">
            <!-- Click background to close -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseLanguageModalCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="#1E1E2E"
                    VerticalOptions="End"
                    Margin="0"
                    Padding="20,15,20,30"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0">
                <!-- Prevent closing when clicking inside the sheet -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DummyCommand}" />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="18">
                    <!-- Handle UI indicator -->
                    <BoxView HeightRequest="4" WidthRequest="40" Color="#4A4A5A" CornerRadius="2" HorizontalOptions="Center"/>

                    <Label Text="{Binding UiTexts.LanguageModalTitle}" FontSize="18" FontAttributes="Bold" TextColor="#F0A030" HorizontalOptions="Center" Margin="0,10,0,0"/>

                    <!-- Picker ngôn ngữ thuyết minh (giữ nguyên UI và logic) -->
                    <Label Text="{Binding NarrationLanguageLabel, FallbackValue='Ngôn ngữ thuyết minh'}"
                           FontSize="12"
                           TextColor="#888888"
                           Margin="2,0,0,-6"/>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#1E2E2E"
                            Padding="10,4">
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Picker -->
                            <Picker ItemsSource="{Binding Languages}"
                                    ItemDisplayBinding="{Binding Label}"
                                    SelectedItem="{Binding SelectedLanguage}"
                                    TextColor="White"
                                    FontSize="12"
                                    SelectedIndexChanged="OnLanguagePickerChanged"/>

                            <!-- Icon dropdown -->
                            <Label Grid.Column="1"
                                   Text="{Binding UiTexts.DropdownArrow}"
                                   FontSize="12"
                                   TextColor="#888888"
                                   VerticalOptions="Center"
                                   Margin="0,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Picker ngôn ngữ hệ thống -->
                    <Label Text="{Binding SystemLanguageLabel, FallbackValue='Ngôn ngữ hệ thống'}"
                           FontSize="12"
                           TextColor="#888888"
                           Margin="2,10,0,-6"/>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#1E2E2E"
                            Padding="10,4" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <Picker ItemsSource="{Binding Languages}"
                                    ItemDisplayBinding="{Binding Label}"
                                    SelectedItem="{Binding SelectedSystemLanguage}"
                                    TextColor="White"
                                    FontSize="12"
                                    SelectedIndexChanged="OnSystemLanguagePickerChanged"/>
                            <Label Grid.Column="1"
                                   Text="{Binding UiTexts.DropdownArrow}"
                                   FontSize="12"
                                   TextColor="#888888"
                                   VerticalOptions="Center"
                                   Margin="0,0,4,0"/>
                        </Grid>
                    </Border>

                    <Button Text="{Binding UiTexts.CommonClose}"
                            Command="{Binding CloseLanguageModalCommand}"
                            BackgroundColor="#2A2A3A"
                            TextColor="#CCCCCC"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="20" HeightRequest="44"
                            Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
