<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodStreetMAUI.Models"
             x:Class="FoodStreetMAUI.Views.PoiListPage"
             Title="Điểm thuyết minh"
             BackgroundColor="#0F0F16">
    <ScrollView BackgroundColor="#0F0F16">
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Pois}"
                             Margin="10,10,10,10" Spacing="6">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="models:PointOfInterest">
                    <Border Padding="12,10" StrokeShape="RoundRectangle 12"
                            StrokeThickness="0.5" BackgroundColor="#1A1A26" Stroke="#2A2A3A">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPoiTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="40,*,Auto">
                                <Label Grid.Column="0" Text="{Binding Emoji}"
                                       FontSize="22" VerticalOptions="Center" HorizontalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="#D0D0E8"/>
                                    <Label Text="{Binding Category}" FontSize="11" TextColor="#555555"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" Padding="12,8"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        BackgroundColor="#2A2A3A" VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayAudioTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="🔊" FontSize="14" VerticalOptions="Center" HorizontalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- Phần mô tả (mặc định ẩn) -->
                            <Label Text="{Binding Contents[vi].Description}" 
                                   IsVisible="False" 
                                   FontSize="12" TextColor="#AAAAAA" 
                                   Margin="40,8,10,10"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>