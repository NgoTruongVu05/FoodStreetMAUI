<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FoodStreetGuide.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:helpers="clr-namespace:FoodStreetGuide.Helpers">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ── Value Converters (app-wide) ── -->
            <helpers:BoolToColorConverter       x:Key="BoolToColor"/>
            <helpers:BoolToTourLabelConverter   x:Key="BoolToTourLabel"/>
            <helpers:BoolToGreenRedConverter    x:Key="BoolToGreenRed"/>
            <helpers:LanguageToColorConverter   x:Key="LangToColor"/>
            <helpers:TabColorConverter          x:Key="TabColor"/>
            <helpers:TabVisibleConverter        x:Key="TabVisible"/>
            <helpers:GeofenceStateToColorConverter x:Key="GeoStateColor"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
