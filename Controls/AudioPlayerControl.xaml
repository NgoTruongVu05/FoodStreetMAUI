<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="FoodStreetGuide.Controls.AudioPlayerControl"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FoodStreetGuide.ViewModels"
    x:DataType="vm:AudioPlayerViewModel">

    <Border BackgroundColor="#18182E"
            StrokeThickness="0.5"
            Stroke="#2A2A4A"
            StrokeShape="RoundRectangle 14"
            Padding="14"
            Margin="0,0,0,8">
        <VerticalStackLayout Spacing="10">

            <!-- Header: status + source badge -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Ellipse Grid.Column="0"
                         WidthRequest="8" HeightRequest="8"
                         Fill="#22C55E"
                         VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding SourceLabel}"
                       TextColor="#85B7EB"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalOptions="Center"/>
                <!-- TTS Toggle -->
                <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                    <Label Text="TTS"
                           TextColor="#888780"
                           FontSize="11"
                           VerticalOptions="Center"/>
                    <Switch IsToggled="{Binding TtsEnabled}"
                            OnColor="#378ADD"
                            ThumbColor="White"
                            Scale="0.75"
                            VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- Track title -->
            <Label Text="{Binding TrackTitle}"
                   TextColor="White"
                   FontSize="15"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation"/>

            <!-- Description -->
            <Label Text="{Binding TrackDescription}"
                   TextColor="#888780"
                   FontSize="12"
                   LineBreakMode="WordWrap"
                   MaxLines="3"/>

            <!-- Waveform visual (animated via code-behind) -->
            <BoxView x:Name="WaveformPlaceholder"
                     HeightRequest="28"
                     BackgroundColor="Transparent"/>

            <!-- Progress bar + time -->
            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                <Slider Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                        Minimum="0" Maximum="100"
                        Value="{Binding ProgressPercent}"
                        ThumbColor="#378ADD"
                        MinimumTrackColor="#378ADD"
                        MaximumTrackColor="#2A2A4A"
                        HeightRequest="20"/>
                <Label Grid.Row="1" Grid.Column="0"
                       Text="{Binding PositionText}"
                       TextColor="#888780"
                       FontSize="11"/>
                <Label Grid.Row="1" Grid.Column="2"
                       Text="{Binding DurationText}"
                       TextColor="#888780"
                       FontSize="11"/>
            </Grid>

            <!-- Playback controls -->
            <Grid ColumnDefinitions="*,*,*,*,*" HeightRequest="48">
                <!-- Skip back -->
                <Button Grid.Column="0"
                        Text="⏮"
                        BackgroundColor="Transparent"
                        TextColor="#888780"
                        FontSize="16"
                        Command="{Binding SkipBackCommand}"
                        BorderColor="#2A2A4A"
                        BorderWidth="0.5"
                        CornerRadius="20"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="Center"/>

                <!-- Play/Pause -->
                <Button Grid.Column="2"
                        Text="{Binding PlayPauseIcon}"
                        BackgroundColor="#185FA5"
                        TextColor="White"
                        FontSize="18"
                        Command="{Binding TogglePlayPauseCommand}"
                        CornerRadius="22"
                        WidthRequest="44" HeightRequest="44"
                        HorizontalOptions="Center"/>

                <!-- Skip forward -->
                <Button Grid.Column="4"
                        Text="⏭"
                        BackgroundColor="Transparent"
                        TextColor="#888780"
                        FontSize="16"
                        Command="{Binding SkipForwardCommand}"
                        BorderColor="#2A2A4A"
                        BorderWidth="0.5"
                        CornerRadius="20"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="Center"/>
            </Grid>

        </VerticalStackLayout>
    </Border>
</ContentView>
