<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="FoodStreetGuide.Controls.PoiCardControl"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FoodStreetGuide.ViewModels"
    x:DataType="vm:PoiViewModel">

    <Border BackgroundColor="#18182E"
            StrokeThickness="0.5"
            Stroke="{Binding StateBadgeColor}"
            StrokeShape="RoundRectangle 12"
            Padding="12,10"
            Margin="0,0,0,8">

        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding SelectCommand}"
                                  CommandParameter="{Binding .}" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

            <!-- Emoji icon -->
            <Border Grid.Column="0"
                    BackgroundColor="#1E1E3A"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="38" HeightRequest="38"
                    VerticalOptions="Center">
                <Label Text="{Binding Emoji}"
                       FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Name + meta + state badge -->
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Title}"
                       TextColor="White"
                       FontSize="13"
                       FontAttributes="Bold"
                       LineBreakMode="TailTruncation"/>
                <Label Text="{Binding Meta}"
                       TextColor="#888780"
                       FontSize="11"
                       LineBreakMode="TailTruncation"/>
                <!-- State badge -->
                <Border BackgroundColor="{Binding StateBadgeColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 4"
                        Padding="6,2"
                        HorizontalOptions="Start">
                    <Label Text="{Binding StateLabel}"
                           TextColor="{Binding StateBadgeTextColor}"
                           FontSize="10"
                           FontAttributes="Bold"/>
                </Border>
            </VerticalStackLayout>

            <!-- Distance -->
            <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="End"
                                 VerticalOptions="Center"
                                 Spacing="0">
                <Label Text="{Binding DistanceLabel}"
                       TextColor="#85B7EB"
                       FontSize="13"
                       FontAttributes="Bold"
                       HorizontalOptions="End"/>
            </VerticalStackLayout>

        </Grid>
    </Border>
</ContentView>
