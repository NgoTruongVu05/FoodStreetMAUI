<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="FoodStreetGuide.Controls.SystemStatusControl"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FoodStreetGuide.ViewModels"
    x:DataType="vm:MainViewModel">

    <VerticalStackLayout Spacing="8">

        <!-- GPS Stats row -->
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

            <Border Grid.Column="0" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="GPS Mode" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding GpsModeText}" TextColor="#4ADE80" FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Độ chính xác" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding GpsAccuracyText}" TextColor="#60A5FA" FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="2" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Interval" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding GpsIntervalText}" TextColor="#FBBF24" FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Stats row 2 -->
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Border Grid.Column="0" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="POI hoạt động" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding Pois.Count}" TextColor="#60A5FA" FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Triggered" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding TriggeredCount}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="2" BackgroundColor="#18182E"
                    StrokeThickness="0.5" Stroke="#2A2A4A"
                    StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tour" TextColor="#888780" FontSize="10"/>
                    <Label Text="{Binding IsTourRunning, StringFormat='{0:Đang chạy|Dừng}'}"
                           TextColor="{Binding IsTourRunning, Converter={StaticResource BoolToGreenRed}}"
                           FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Debounce info -->
        <Border BackgroundColor="#18182E"
                StrokeThickness="0.5" Stroke="#2A2A4A"
                StrokeShape="RoundRectangle 10" Padding="12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <Label Grid.Row="0" Grid.Column="0"
                       Text="Anti-spam debounce"
                       TextColor="#888780" FontSize="11"/>
                <Label Grid.Row="0" Grid.Column="1"
                       Text="120s / POI"
                       TextColor="#FBBF24" FontSize="12" FontAttributes="Bold"/>
                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Cooldown giữa 2 lần trigger cùng POI. Áp dụng riêng cho từng điểm."
                       TextColor="#555555" FontSize="11"
                       Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- Audio source -->
        <Border BackgroundColor="#18182E"
                StrokeThickness="0.5" Stroke="#2A2A4A"
                StrokeShape="RoundRectangle 10" Padding="12">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Nguồn audio" TextColor="#888780" FontSize="11"/>
                    <Label Text="Studio MP3 → fallback TTS"
                           TextColor="#D3D1C7" FontSize="12"/>
                </VerticalStackLayout>
                <Label Grid.Column="1"
                       Text="● Online"
                       TextColor="#4ADE80"
                       FontSize="12"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Geofence algorithm info -->
        <Border BackgroundColor="#18182E"
                StrokeThickness="0.5" Stroke="#2A2A4A"
                StrokeShape="RoundRectangle 10" Padding="12">
            <VerticalStackLayout Spacing="4">
                <Label Text="Thuật toán Geofence" TextColor="#888780" FontSize="11"/>
                <Label Text="Haversine distance · Evaluate mỗi GPS update · 3 trạng thái: Outside / Nearby / Inside"
                       TextColor="#D3D1C7" FontSize="11" LineBreakMode="WordWrap"/>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>
